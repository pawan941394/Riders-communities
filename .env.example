# --- Local dev (defaults are fine) ---
# FastAPI API access key for X-API-Key header (App + web must send this on protected routes)
FASTAPI_X_API_KEY=change-this-to-a-strong-secret

# JWT signing for rider auth (must match across restarts; use a long random string in production)
FASTAPI_JWT_SECRET=change-this-to-a-different-strong-secret
# FASTAPI_JWT_EXP_MINUTES=10080

# Optional: base URL for absolute media when the request host is not available (e.g. Android emulator: http://10.0.2.2:8000)
PUBLIC_BASE_URL=http://127.0.0.1:8000

# --- DigitalOcean / production (set in server .env only) ---
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=false
# ALLOWED_HOSTS=bharataiconnect.com,www.bharataiconnect.com,123.45.67.89
# PUBLIC_BASE_URL=https://bharataiconnect.com
# BEHIND_HTTPS_PROXY=true
# CSRF_TRUSTED_ORIGINS=https://bharataiconnect.com,https://www.bharataiconnect.com
# CORS_ALLOWED_ORIGINS=https://bharataiconnect.com,https://www.bharataiconnect.com

