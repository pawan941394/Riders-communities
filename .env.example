# FastAPI API access key for X-API-Key header
FASTAPI_X_API_KEY=change-this-to-a-strong-secret

# Optional: base URL for absolute media links when the request host is not available (Android emulator: http://10.0.2.2:8000).
# Buy/Rent EV partner images use the incoming request host when possible.
PUBLIC_BASE_URL=http://127.0.0.1:8000

